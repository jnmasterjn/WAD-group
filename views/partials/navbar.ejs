<div style="
    width:100%;
    border-bottom:1px solid #ddd;
    padding:12px 30px;
    box-sizing:border-box;
    background:white;
    position: sticky;
    top: 0;
    z-index: 1000;
">

    <nav style="
        display:flex;
        align-items:center;
        max-width:2000px;
        margin:0 auto;
    ">

        <!-- LEFT -->
        <div style="display:flex; gap:25px; font-weight:500;">
            <a href="/movie" style="text-decoration:none; color:#333;">All Movies</a>
            <a href="/watchlist" style="text-decoration:none; color:#333;">My Watchlist</a>
            <a href="/watched" style="text-decoration:none; color:#333;">Watched Movies</a>
            <a href="/myReviews" style="text-decoration:none; color:#333;">My Reviews</a>
        </div>

        <!-- RIGHT -->
        <div style="
            display:flex;
            gap:15px;
            align-items:center;
            margin-left:auto;
        ">
            <% if (username) { %>
                <span style="color:#555;">
                    Logged in as 
                    <a href="/profile" style="text-decoration:none; color:#000; font-weight:500;">
                        <%= username %>
                    </a>
                </span>

                <a href="/logout" 
                    style="
                        text-decoration:none;
                        color:white;
                        background:#333;
                        padding:6px 12px;
                        border-radius:6px;
                ">
                    Logout
                </a>

            <% } else { %>

                <a href="/login" 
                    style="text-decoration:none; color:#333;">
                    Login
                </a>

                <a href="/register" 
                    style="
                        text-decoration:none;
                        color:white;
                        background:#333;
                        padding:6px 12px;
                        border-radius:6px;
                ">
                    Register
                </a>

            <% } %>
        </div>

    </nav>
</div>