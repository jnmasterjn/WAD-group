<html>
    <body style="
        display:flex;
        justify-content:center;
        align-items:center;
        height:100vh;
        margin:0;
    ">

        <div style="
            text-align:center;
            padding:30px;
            border:1px solid #ddd;
            border-radius:10px;
            width:300px;
        ">

            <h1>Login</h1>

            <% if (success) { %>
                <p style="color:green;">Account created successfully, please login</p>
            <% } %>

            <% if (error) { %>
                <p style="color:red;"><%= error %></p>
            <% } %>

            <form method="POST" action="/login" style="
                display:flex;
                flex-direction:column;
                gap:10px;
            ">

                <input type="text" name="username" placeholder="Username" maxlength="20" required>

                <input type="password" name="password" placeholder="Password" maxlength="40" required>

                <button type="submit">Login</button>

            </form>

            <br>

            <a href="/register">Don't have an account? Register</a>

        </div>

    </body>
</html>