<html>
    <body>
        <h1>Login</h1>
        <% if (success) { %>
            <p style="color:green;">Account created successfully, please Login</p>
        <% } %>
        
        <% if (error) { %>
            <p style="color:red;"><%= error %></p>
        <% } %>

        <form method="POST" action="/login">
            Username: 
            <input type="text" name="username" placeholder="Enter Username" maxlength="20" required>
            <br>
            Password: 
            <input type="password" name="password" placeholder="Enter Password" maxlength="40" required>
            <br><br>

            <button type="submit">Login</button>
        </form>
        <a href="/register">Don't have an account? Register</a>
    </body>
</html>

