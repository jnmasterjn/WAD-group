<!DOCTYPE html>
<html>

<body style="margin:0;">

    <!-- navbar (full width, not inside flex) -->
    <%- include("./partials/navbar") %>

    <!-- center ONLY the card -->
    <div style="
        display:flex;
        justify-content:center;
        padding:40px 0;
    ">

    <div style="
        width:600px;
        padding:30px;
        border:1px solid #ddd;
        border-radius:10px;
    ">

        <h1 style="text-align:center;">My Reviews</h1>    

        <!-- Message when no reviews are given -->
        <% if (reviews.length === 0) { %>

            <p>No Reviews yet.</p>

        <% } else { %>

        <!-- loop to render each movie -->
        <% reviews.forEach(review => { %>

            <div style="
                border-bottom:1px solid #eee;
                padding:10px 0;
                margin-bottom:15px;
            ">

                <% if (review.movie) { %>

                    <p><strong><%= review.movie.title %></strong></p>

                    <a href="/movie/<%= review.movie._id %>">
                        <img src="<%= review.movie.image %>" style="width:160px; border-radius:20px;">
                    </a>

                <% } else { %>

                    <p style="color:red;">[Movie deleted]</p>

                <% } %>

                <p><strong>Rating:</strong> <%= review.rating %>/5</p>
                <p><strong>Comment:</strong> <%= review.comment %></p>

                <!-- edit review button -->
                <button id="UserEditButton-<%= review._id %>" 
                        type="button" 
                        onclick="showEdit('<%= review._id %>')">
                    Edit Review
                </button>

                <form id="form-<%= review._id %>" 
                    action="/review/edit/<%= review._id %>" 
                    method="POST" 
                    style="display:none; margin-top:10px;">

                    <label>Rating:</label><br>
                    <input type="number" name="rating" min="1" max="5" value="<%= review.rating %>"> 
                    
                    <br> 

                    <label>Content:</label><br>
                    <textarea name="comment" rows="4" maxlength="500"><%= review.comment %></textarea>

                    <br><br>

                    <button type="submit">Save</button>
                    <button type="button" onclick="hideEdit('<%= review._id %>')">Cancel</button>
                </form>

                <!-- error handling -->
                <% if (typeof error !== 'undefined' && error) { %> 
                    <p style="color:red;"><%= error %></p>
                <% } %>
                
                <!-- Delete Review Button -->
                <form action="/review/delete/<%= review._id %>" method="POST">
                    <button type="submit" onclick="return confirm('Are you sure you want to delete this review?')">
                        Delete Comment
                    </button>
                </form>

            </div>

        <% }); %>

        <% } %>

        <br> 
        <a href="/movie">← Back to Movies</a>

    </div>
    </div>

    <script>
        function showEdit(id) {
            document.getElementById("form-" + id).style.display = "block";
            document.getElementById("UserEditButton-" + id).style.display = "none";
        }
        
        function hideEdit(id) {
            document.getElementById("form-" + id).style.display = "none";
            document.getElementById("UserEditButton-" + id).style.display = "inline-block";
        }
    </script>        

</body>
</html>