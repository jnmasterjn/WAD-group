<%- include("./partials/navbar") %>
<html>
    <head>
        <title>Reviews</title>
    </head>
        <body>
            <h1>My Reviews</h1>
                
            <% if (reviews.length === 0) { %>
                <!-- Message when no reviews are given -->
                <p>No Reviews yet.</p>
            <% } else { %>
                <!-- loop to render each movie -->
                <% reviews.forEach(review => { %>
                    <p><%= review.movie.title %></p>
                    <a href="/movie/<%= review.movie._id %>">
                        <img src="<%= review.movie.image %>" 
                            style="width:160px; border-radius: 20px;">
                    </a>
                    
                    <p><strong>Rating:</strong> <%= review.rating %>/5</p>
                    <p><strong>Comment:</strong> <%= review.comment %></p>

                    <!-- edit review button -->
                    <button id="editButton-<%= review._id %>" type="button" onclick="showEdit('<%= review._id %>')">Edit Comment</button>
                    <form id="form-<%= review._id %>" action="/review/edit/<%= review._id %>" method="POST" style="display:none;">
                        <textarea name="comment" maxlength="500"><%= review.comment %></textarea> 
                            <br><br>
                            <button type="submit">Save</button>
                            <button type="button" onclick="hideEdit('<%= review._id %>')">Cancel</button>
                    </form>
                    
                    <form action="/review/delete/<%= review._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this comment?')">
                        <button type="submit">Delete Comment</button>
                    </form>

                    <br><br>
                <% }); %>
            <% } %>
        </body>
    </html>

<script>
    function showEdit(id) {
        document.getElementById("form-" + id).style.display = "block";
        document.getElementById("editButton-" + id).style.display = "none";
    }
        
    function hideEdit(id) {
        document.getElementById("form-" + id).style.display = "none";
        document.getElementById("editButton-" + id).style.display = "block";
    }
</script>