<!DOCTYPE html>
<html>
<head>
    <title>Reviews</title>
</head>
<body>
    <%- include("./partials/navbar") %>

    <h1>My Reviews</h1>    
    <!-- Message when no reviews are given -->
    <% if (reviews.length === 0) { %>
    <p>No Reviews yet.</p>
    <% } else { %>
    <!-- loop to render each movie -->
    <% reviews.forEach(review => { %>
        <p><%= review.movie.title %></p>
        <a href="/movie/<%= review.movie._id %>">
            <img src="<%= review.movie.image %>" style="width:160px; border-radius: 20px;">
        </a>
        <p><strong>Rating:</strong><%= review.rating %>/5</p>
        <p style="width: 1500px;overflow-wrap: break-word;"><strong>Comment:</strong><%= review.comment %></p>

        <!-- edit review button -->
        <button id="UserEditButton-<%= review._id %>" type="button" onclick="showEdit('<%= review._id %>')">Edit Review</button>
        <form id="form-<%= review._id %>" action="/review/edit/<%= review._id %>" method="POST" style="display:none;">
        <label>Rating:</label><br>
            <input type="number" name="rating" min="1" max="5" value="<%= review.rating %>"> 
            <br> 
            <label>Content:</label><br>
            <textarea name="comment" rows="5" cols="30" maxlength="500"><%= review.comment %></textarea>
            <br><br>
            <button type="submit">Save</button>
            <button type="button" onclick="hideEdit('<%= review._id %>')">Cancel</button>
        </form>

        <!-- error handling -->
        <% if (typeof error !== 'undefined' && error) { %> 
            <p style="color:red;"><%= error %></p>
        <% } %>
        
        <!-- Delete Review Button -->
        <form action="/review/delete/<%= review._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this review?')">
            <button type="submit">Delete Comment</button>
        </form>
        <% }); %>
    <% } %>
<script>
    function showEdit(id) {
        document.getElementById("form-" + id).style.display = "block";
        document.getElementById("UserEditButton-" + id).style.display = "none";
    }
        
    function hideEdit(id) {
        document.getElementById("form-" + id).style.display = "none";
        document.getElementById("UserEditButton-" + id).style.display = "block";
    }
</script>        

<br> 
<a href="/movie">Back to Movies</a>

</body>
</html>
