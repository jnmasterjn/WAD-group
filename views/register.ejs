    <html>
        <body>
            <h1>Register</h1>
            <% if (error) { %>
                <span style="color: red;"><%= error %></span>
            <% } %>
            <form method="POST" action="/register">
                Username: <input type="text" name="username" placeholder="Username" maxlength="20" required><br>
                Password: <input type="password" name="password" placeholder="Password" maxlength="40" required><br>
                <button type="submit">Register</button>
                <br>
                <a href="/login">Already have an account? Login</a>
            </form>
        </body>
    </html>
