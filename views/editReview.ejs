<%- include("./partials/navbar") %>
<html>
    <head>
        <title>Edit Review</title>
    </head>
    <body>
        <h1>Edit Review</h1>

        <form action="/review/edit/<%= review._id %>" method="post">
            
            <label>Comment:</label><br>
            <textarea name="comment"><%= review.comment %></textarea><br><br>
        
            <label>Rating:</label><br>
            <input type="number" name="rating" value="<%= review.rating %>" min="1" max="5"><br><br>
        
            <button type="submit">Update Review</button>

        </form>
    </body>
</html>
